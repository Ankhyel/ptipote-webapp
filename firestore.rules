rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isBootstrapAdmin() {
      return signedIn()
        && request.auth.uid in ['taNxWXLMh2gJx5CHgmBB8Phl4c93'];
    }

    function isAdmin() {
      return signedIn()
        && (
          isBootstrapAdmin()
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        );
    }

    function isDev() {
      return signedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'dev';
    }

    function canReadDashboard() {
      return isAdmin() || isDev();
    }

    function ownCreateKeepsRole(userId) {
      return signedIn()
        && request.auth.uid == userId
        && (
          !('role' in request.resource.data)
          || request.resource.data.role == 'user'
          || (isBootstrapAdmin() && request.resource.data.role == 'admin')
        );
    }

    function ownUpdateKeepsRole(userId) {
      return signedIn()
        && request.auth.uid == userId
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])
          || (
            isBootstrapAdmin()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role', 'updatedAt'])
            && request.resource.data.role == 'admin'
          )
        );
    }

    function adminRoleUpdate() {
      return isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role', 'updatedAt'])
        && request.resource.data.role in ['user', 'dev'];
    }

    match /users/{userId} {
      allow get, list: if signedIn();
      allow create: if ownCreateKeepsRole(userId);
      allow update: if ownUpdateKeepsRole(userId) || adminRoleUpdate();
      allow delete: if false;

      match /figurines/{figurineId} {
        allow read: if (request.auth != null && request.auth.uid == userId) || canReadDashboard();
        allow write: if request.auth != null && request.auth.uid == userId;
        allow update, delete: if request.auth != null
          && (
            resource.data.transfer.toUid == request.auth.uid
            || (
              exists(/databases/$(database)/documents/transferRequests/$(userId + '_' + figurineId + '_' + request.auth.uid))
              && get(/databases/$(database)/documents/transferRequests/$(userId + '_' + figurineId + '_' + request.auth.uid)).data.fromUid == userId
              && get(/databases/$(database)/documents/transferRequests/$(userId + '_' + figurineId + '_' + request.auth.uid)).data.toUid == request.auth.uid
              && get(/databases/$(database)/documents/transferRequests/$(userId + '_' + figurineId + '_' + request.auth.uid)).data.status in ['accepted', 'confirmed']
            )
            || (
              exists(/databases/$(database)/documents/users/$(request.auth.uid)/incomingTransfers/$(figurineId))
              && get(/databases/$(database)/documents/users/$(request.auth.uid)/incomingTransfers/$(figurineId)).data.fromUid == userId
              && get(/databases/$(database)/documents/users/$(request.auth.uid)/incomingTransfers/$(figurineId)).data.status == 'accepted'
            )
          );
      }

      match /friends/{friendId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null
          && (request.auth.uid == userId || request.resource.data.uid == request.auth.uid);
      }

      match /incomingTransfers/{transferId} {
        allow read, update: if request.auth != null && request.auth.uid == userId;
        allow delete: if request.auth != null
          && (request.auth.uid == userId || resource.data.fromUid == request.auth.uid);
        allow create: if request.auth != null
          && (
            request.auth.uid == userId
            || (
              request.resource.data.toUid == userId
              && request.resource.data.fromUid == request.auth.uid
            )
          );
      }

      match /notifications/{notificationId} {
        allow read, update, delete: if request.auth != null
          && request.auth.uid == userId;
        allow create: if request.auth != null
          && request.resource.data.recipientUid == userId;
      }

      match /fcmTokens/{tokenId} {
        allow read, write, delete: if request.auth != null
          && request.auth.uid == userId;
      }
    }

    match /publicProfiles/{userId} {
      allow get, list: if request.auth != null;
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.uid == request.auth.uid;
      allow delete: if false;
    }

    match /friendInvites/{inviteId} {
      allow read: if request.auth != null
        && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.fromUid == request.auth.uid;
      allow update: if request.auth != null
        && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
    }

    match /transferRequests/{transferId} {
      allow read, update: if request.auth != null
        && (
          resource.data.fromUid == request.auth.uid
          || resource.data.toUid == request.auth.uid
          || canReadDashboard()
        );
      allow create: if request.auth != null
        && request.resource.data.fromUid == request.auth.uid;
    }

    match /chats/{chatId} {
      allow read, update: if request.auth != null
        && request.auth.uid in resource.data.participantUids;
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participantUids;

      match /messages/{messageId} {
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantUids;
        allow create: if request.auth != null
          && request.resource.data.senderUid == request.auth.uid
          && request.auth.uid in getAfter(/databases/$(database)/documents/chats/$(chatId)).data.participantUids;
        allow update, delete: if false;
      }
    }

    match /publicFigurines/{figurineId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid;
      allow update: if request.auth != null
        && (resource.data.ownerUid == request.auth.uid || request.resource.data.ownerUid == request.auth.uid);
      allow delete: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;
    }
  }
}
